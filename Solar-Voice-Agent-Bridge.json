        "calendar": { "__rl": true, "mode": "id", "value": "={{ $json.calendar_id || \"primary\" }}" },
        "timeMin": "={{ $json.start_iso }}",
        "timeMax": "={{ $json.end_iso }}",
        "options": { "outputFormat": "availability" }
      },
      "name": "Google Calendar - Check Candidate Slot",
