      "parameters": {
        "jsCode": "// [NDA SUMMARY] Validates candidate time slots: must be on the hour, 8AM-4PM, exactly 1 hour.\n// Parses ISO-8601 datetimes, filters valid slots, passes to Google Calendar for checking.\nconst slots = (body.slots || []).filter(s => {\n  const h = new Date(s.start).getHours();\n  return h >= 8 && h <= 16 && s.start.endsWith(':00');\n});\nreturn slots.map((s, i) => ({ json: { slot_label: s.label, start_iso: s.start, end_iso: s.end } }));"
      },
      "name": "Code - Expand Requested Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [224, 224]
    },
