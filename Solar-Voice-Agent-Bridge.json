      "parameters": {
        "jsCode": "// [NDA SUMMARY] Matches the incoming phone number against active companies in Baserow.\n// Normalizes phone numbers (strip non-digits), finds exact match, checks Active=true flag.\n// Returns company config: name, agent_name, calendar_id, timezone, email.\nconst phone = String($input.first().json.body.phone_number).trim();\nconst rows = $input.all().map(item => item.json);\nconst normalize = (v) => String(v || '').replace(/[^0-9+]/g, '');\nconst wanted = normalize(phone);\nconst found = rows.filter(r => normalize(r['Twilio Number']) === wanted)\n                  .find(r => r['Active'] === true);\nif (!found) return [{ json: { identity_found: false } }];\nreturn [{ json: { identity_found: true, company_name: found['Company Name'], agent_name: found['Agent Name'], /* ... */ } }];"
      },
      "name": "Code - Match Company By Twilio",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [448, 0]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ identity_found: !!$json.identity_found, company_name: $json.company_name || \"\", agent_name: $json.agent_name || \"[REDACTED]\", /* ... */ }) }}"
      },
      "name": "Respond - Company Found",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [672, 0]
