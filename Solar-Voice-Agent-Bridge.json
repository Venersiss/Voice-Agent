      "parameters": {
        "jsCode": "// [NDA SUMMARY] Collects available slots from Google Calendar responses.\n// Filters to available=true, sorts by slot index, returns compact slot list.\nconst available = $input.all().filter(i => i.json.available)\n  .sort((a, b) => (a.json.slot_index || 0) - (b.json.slot_index || 0));\nconst labels = available.map(i => i.json.slot_label).filter(Boolean);\nreturn [{ json: { available: labels.length > 0, slots: labels } }];"
      },
      "name": "Code - Collect Available Slots",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [672, 224]
